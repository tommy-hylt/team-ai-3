{
  "name": "claude-opus",
  "executable": "claude",
  "args": [
    {
      "type": "basic",
      "parts": [
        "--model",
        "opus",
        "--dangerously-skip-permissions",
        "--print",
        "--verbose",
        "--output-format",
        "stream-json"
      ]
    },
    {
      "type": "resume",
      "parts": [
        "-r"
      ]
    }
  ]
}
